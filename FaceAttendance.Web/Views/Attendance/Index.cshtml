@{
    ViewData["Title"] = "Điểm Danh Bằng Camera";
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <label class="fw-bold">Chọn Lớp Đang Học:</label>
                <select id="classIdSelect" class="form-select">
                    <option value="0">-- Quét toàn bộ trường (Chế độ Test) --</option>
                    <option value="1">Lớp IT01 - Lập trình Web</option>
                    <option value="2">Lớp IT02 - Trí tuệ nhân tạo</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="fw-bold">Mã Phiên Điểm Danh:</label>
                <input type="number" id="sessionIdSelect" class="form-control" value="1" />
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="m-0"><i class="fa-solid fa-video text-danger"></i> Camera Lớp Học</h5>
                <button id="btnStartCamera" class="btn btn-success btn-sm">Mở Camera</button>
            </div>
            <div class="card-body text-center bg-light">
                <video id="videoElement" autoplay playsinline style="width: 100%; max-height: 480px; border-radius: 8px; background: #000; transform: scaleX(-1);"></video>

                <canvas id="canvasElement" style="display:none;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="m-0"><i class="fa-solid fa-clipboard-check"></i> Kết Quả Nhận Diện</h5>
            </div>
            <div class="card-body" id="attendanceResults" style="overflow-y: auto; max-height: 480px;">
                <p class="text-muted fst-italic">Đang chờ mở camera...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const video = document.getElementById('videoElement');
        const canvas = document.getElementById('canvasElement');
        const btnStart = document.getElementById('btnStartCamera');
        const resultsDiv = document.getElementById('attendanceResults');
        let attendanceInterval;

        // 1. Sự kiện khi bấm nút "Mở Camera"
        btnStart.addEventListener('click', async () => {
            try {
                // Xin quyền mở Webcam của trình duyệt
                const stream = await navigator.mediaDevices.getUserMedia({ video: true });
                video.srcObject = stream;

                btnStart.textContent = "Đang chạy AI...";
                btnStart.classList.replace('btn-success', 'btn-warning');
                btnStart.disabled = true;
                resultsDiv.innerHTML = ""; // Xóa dòng chữ chờ

                // Hẹn giờ: Cứ mỗi 3 giây (3000ms) thì gọi hàm chụp ảnh 1 lần
                attendanceInterval = setInterval(captureAndSendFrame, 3000);

            } catch (err) {
                alert("Lỗi không thể mở Camera: " + err.message);
            }
        });

        // 2. Hàm chụp ảnh và gửi lên Server bằng AJAX (Fetch API)
        async function captureAndSendFrame() {
            // Lấy kích thước thật của video
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            const ctx = canvas.getContext('2d');

            // Vẽ khung hình hiện tại từ thẻ <video> sang thẻ <canvas>
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

            // Ép ảnh thành dạng chuỗi văn bản (Base64) để dễ dàng gửi qua mạng
            const base64Image = canvas.toDataURL('image/jpeg');

            try {
                // Giả sử có 2 thẻ <select> hoặc Input ẩn lưu ID lớp và phiên điểm danh
                let currentClassId = document.getElementById("classIdSelect").value;
                let currentSessionId = document.getElementById("sessionIdSelect").value;

                let currentClassId = classSelect ? classSelect.value : 0;
                let currentSessionId = sessionSelect ? sessionSelect.value : 0;

                fetch(`/Attendance/Recognize?classId=${currentClassId}&sessionId=${currentSessionId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ Base64Image: imageData })
                });

                const result = await response.json();

                // Giới hạn chỉ hiện 5 kết quả mới nhất để không bị tràn màn hình
                if (resultsDiv.children.length > 5) {
                    resultsDiv.removeChild(resultsDiv.lastChild);
                }

                // Nếu nhận diện thành công (Màu xanh)
                if (result.success) {
                    const logHtml = `
                        <div class="alert alert-success py-2 mb-2">
                            <i class="fa-solid fa-check-circle"></i>
                            <strong>${result.studentName}</strong>
                            <span class="badge bg-success float-end">${result.percent}%</span>
                        </div>
                    `;
                    resultsDiv.insertAdjacentHTML('afterbegin', logHtml);
                }
                // Nếu thất bại hoặc người lạ (Màu vàng)
                else {
                    const errHtml = `
                        <div class="alert alert-warning py-1 mb-2 opacity-75 small">
                            <i class="fa-solid fa-user-secret"></i> Nhận diện: ${result.message}
                        </div>
                    `;
                    resultsDiv.insertAdjacentHTML('afterbegin', errHtml);
                }
            } catch (err) {
                console.error("Lỗi gửi ảnh lên Server", err);
            }
        }
    </script>
}